{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "启动 Task Scheduler",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}/cmd/scheduler",
            "args": [
                "-config",
                "${workspaceFolder}/config.local.yaml"
            ],
            "env": {},
            "showLog": true,
            "trace": "verbose"
        },
        {
            "name": "启动 Task Scheduler (开发配置)",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}/cmd/scheduler",
            "args": [
                "-config",
                "${workspaceFolder}/config.dev.yaml"
            ],
            "showLog": true,
            "trace": "verbose",
            "dlvFlags": [
                "--check-go-version=false"
            ]
        },
        {
            "name": "启动 Task Scheduler (无配置文件)",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}/cmd/scheduler",
            "args": [],
            "env": {},
            "showLog": true,
            "trace": "verbose"
        },
        {
            "name": "运行当前测试文件",
            "type": "go",
            "request": "launch",
            "mode": "test",
            "program": "${file}",
            "showLog": true
        },
        {
            "name": "运行当前测试函数",
            "type": "go",
            "request": "launch",
            "mode": "test",
            "program": "${file}",
            "args": [
                "-test.run",
                "^${selectedText}$"
            ],
            "showLog": true
        },
        {
            "name": "运行所有测试",
            "type": "go",
            "request": "launch",
            "mode": "test",
            "program": "${workspaceFolder}",
            "args": [
                "-v",
                "./..."
            ],
            "showLog": true
        },
        {
            "name": "附加到进程",
            "type": "go",
            "request": "attach",
            "mode": "local",
            "processId": 0
        }
    ],
    "compounds": [
        {
            "name": "全栈调试 (后端 + 前端)",
            "configurations": [
                "启动 Task Scheduler"
            ],
            "preLaunchTask": "启动前端开发服务器",
            "presentation": {
                "hidden": false,
                "group": "fullstack",
                "order": 1
            }
        }
    ]
}